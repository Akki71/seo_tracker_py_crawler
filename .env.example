# Copy this to .env and fill in your values
# Then run: python startup.py

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=seo_user
DB_PASSWORD=your_password_here
DB_NAME=seo_crawler

# ── AI Providers (set at least one, or use ai_mode=4 to skip AI) ──────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Google PageSpeed (optional — set run_pagespeed=false in API to skip) ──────
PAGESPEED_API_KEY=AIza...

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8000
